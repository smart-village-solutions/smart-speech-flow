# Smart Speech Flow - Environment Variables
# ==========================================

# Redis Configuration
REDIS_URL=redis://redis:6379/0
REDIS_NAMESPACE=ssf

# Client Configuration
CLIENT_BASE_URL=https://translate.smart-village.solutions

# Audio Storage Configuration
# ----------------------------
# Path where audio files are stored (original input + translated output)
AUDIO_STORAGE_PATH=/data/audio

# How long to keep audio files before automatic deletion (in hours)
# Default: 24 hours (for privacy compliance)
AUDIO_RETENTION_HOURS=24

# Temporary storage path for uploads (before processing)
# Use tmpfs mount for better performance
AUDIO_TEMP_PATH=/tmp/audio

# Maximum disk usage for audio storage (in GB)
# Alerts trigger at 80% and 95% of this limit
AUDIO_MAX_DISK_USAGE_GB=9

# Audio cleanup job interval (in minutes)
# Default: 60 (runs hourly)
AUDIO_CLEANUP_INTERVAL_MINUTES=60

# Enable pipeline metadata in WebSocket messages
# Always true for prototype phase
ENABLE_PIPELINE_METADATA=true

# LLM Refinement Configuration
# -----------------------------
# Enable/disable LLM-based translation refinement
LLM_REFINEMENT_ENABLED=true

# LLM model to use for refinement (Ollama format)
LLM_REFINEMENT_MODEL=gpt-oss:20b

# Ollama endpoint URL
LLM_REFINEMENT_ENDPOINT=http://ollama:11434

# Timeout for LLM requests (in seconds)
LLM_REFINEMENT_TIMEOUT=8.0

# LLM sampling temperature (0.0 = deterministic, 1.0 = creative)
LLM_REFINEMENT_TEMPERATURE=0.7

# Maximum retries for failed LLM requests
LLM_REFINEMENT_MAX_RETRIES=2

# Rate Limiting Configuration
# ----------------------------
# Global rate limit (requests per window across all users)
GLOBAL_RATE_LIMIT=1200

# Global rate limit window (in seconds)
GLOBAL_RATE_WINDOW_SECONDS=60

# Per-session message rate limit
MESSAGE_RATE_LIMIT=50

# Per-session message rate limit window (in seconds)
MESSAGE_RATE_WINDOW_SECONDS=10

# Environment Configuration
# --------------------------
# Environment: 'production' or 'development'
ENVIRONMENT=production

# CORS origins for development (comma-separated)
# Only used when ENVIRONMENT=development
DEVELOPMENT_CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Monitoring & Security Configuration
# ------------------------------------
# Grafana Admin Credentials (CHANGE THESE IN PRODUCTION!)
# Generate strong password: openssl rand -base64 32
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_use_strong_password_here

# Frontend Demo Password (CHANGE IN PRODUCTION!)
# This password protects the frontend demo landing page
FRONTEND_DEMO_PASSWORD=changeme_frontend_password
